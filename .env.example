# ============================================================
# 薬育ポケット Phase 2 - 環境変数設定テンプレート
# ============================================================
# このファイルを .env にコピーして API キーを設定してください
# cp .env.example .env
# ============================================================

# Claude API キー（Anthropic Console から取得）
# https://console.anthropic.com/
# 設定するとカメラ画像をClaude Vision AIで植物認識します
# 未設定の場合はモックAI（ランダム判定）が使われます
EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# ============================================================
# セキュリティ注意事項
# ============================================================
# EXPO_PUBLIC_ プレフィックスの変数はアプリバンドルに含まれます。
# 本番配布時はサーバーサイドでAPIを呼び出す構成を推奨します。
# .env ファイルを git にコミットしないでください。
# ============================================================
